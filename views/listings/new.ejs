<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New form</title>
</head>

<body>
    <h2>Add new listings</h2>
    <form action="/listings" method="post">
        <input type="text" name="listing[title]" placeholder="Enter the title">
        <br><br>
        <textarea name="listing[description]" id="" placeholder="enter description"></textarea>
        <br>
        <input type="text" name="listing[image]" id="" placeholder="Enter image url/link">
        <br><br>
        <input type="number" name="listing[price]" id="" placeholder="enter price">
        <br>
        <input type="text" name="listing[country]" id="" placeholder="Enter country">
        <br><br>
        <input type="text" name="listing[location]" id="" placeholder="enter location">
        <br>
<button>Add</button>
    </form>
</body>

</html>