<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>

    <h2>Edit the  listing</h2>
    <form  method="post" action="/listings/<%= listing._id %>?_method=PUT">
        <input type="text" name="listing[title]" value="<%= listing.title %>">
        <br><br>
        <textarea name="listing[description]" id="" ><%= listing.description %></textarea>
        <br>
        <input type="text" name="listing[image]" id="" value="<%= listing.image %>">
        <br><br>
        <input type="number" name="listing[price]" id="" value="<%= listing.price %>">
        <br>
        <input type="text" name="listing[country]" id="" value="<%= listing.country%>">
        <br><br>
        <input type="text" name="listing[location]" id="" value="<%= listing.location %>">
        <br><br>
        <button>Edit</button>
    
</body>
</html>